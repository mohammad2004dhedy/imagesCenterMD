# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret

# Supabase PostgreSQL / Prisma
# Use the Supabase Session Pooler connection string for runtime Prisma queries.
# Example:
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=
# Use the direct Supabase database URL for migrations/db push when available.
DIRECT_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# External image APIs - server-side only
UNSPLASH_ACCESS_KEY=
PIXABAY_API_KEY=
PEXELS_API_KEY=

# Optional Redis cache
REDIS_URL=

# Security and throttling
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
